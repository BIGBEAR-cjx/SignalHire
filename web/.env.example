# Copy to web/.env.local and fill in real values. Never commit .env.local.
#   cp web/.env.example web/.env.local

# MiroMind deep research.
# Required by worker/ for non-cached live research.
MIROMIND_API_KEY=your-miromind-api-key
MIROMIND_BASE_URL=https://api.miromind.ai/v1
MIROMIND_MODEL=mirothinker-1-7-deepresearch-mini

# Insforge server-side DB and queue access.
# Required for history, share links, and queued live research.
# Server-only: do not add a NEXT_PUBLIC_ prefix to these values.
INSFORGE_API_BASE_URL=https://your-project.insforge.app
INSFORGE_API_KEY=your-insforge-access-key

# Insforge client auth base URL.
# Public browser auth SDK value.
NEXT_PUBLIC_INSFORGE_API_BASE_URL=https://your-project.insforge.app

# Optional free public evidence APIs used by worker search prechecks.
# Add these to the worker/server runtime, not to browser-exposed env.
GITHUB_TOKEN=your-github-token
SEMANTIC_SCHOLAR_API_KEY=your-semantic-scholar-api-key
OPENALEX_API_KEY=your-openalex-api-key
HF_TOKEN=your-hugging-face-token
ANYSEARCH_API_KEY=your-anysearch-api-key
OPEN_EVIDENCE_MAX_QUERIES=4
